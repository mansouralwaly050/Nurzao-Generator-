{
  "name": "nurzao-consulting-marketplace",
  "version": "1.0.0",
  "description": "منصة استشارات ذكية - Consulting Marketplace Platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "dev:client": "cd client && vite",
    "dev:server": "cd server && node --loader tsx server.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && tsc",
    "preview": "cd client && vite preview",
    "test": "vitest",
    "lint": "eslint ."
  },
  "keywords": [
    "consulting",
    "marketplace",
    "ai",
    "platform"
  ],
  "author": "Nurzao",
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "express": "^4.18.2",
    "trpc": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "stripe": "^14.0.0",
    "@stripe/react-stripe-js": "^2.0.0",
    "@stripe/stripe-js": "^3.0.0",
    "drizzle-orm": "^0.29.0",
    "drizzle-kit": "^0.20.0",
    "mysql2": "^3.6.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.1.0",
    "zod": "^3.22.0",
    "superjson": "^2.0.0",
    "react-router-dom": "^6.20.0",
    "wouter": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "shadcn-ui": "^0.8.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "lucide-react": "^0.294.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/express": "^4.17.0",
    "@types/bcrypt": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  }
}
